---
const navLinks = [
  { label: "Accueil", href: "/" },
  { label: "Nos Services", href: "/services" },
  { label: "L'entreprise", href: "/a-propos" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="bg-deep text-steel">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <a href="/" class="inline-flex items-center gap-2 mb-4">
          <span class="font-heading text-lg font-bold">
            <span class="text-white">Duval</span>
            <span class="text-sky ml-1">Plomberie</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed mb-4">
          Plombier-chauffagiste depuis 2010.<br />
          Dépannage, installation, rénovation.<br />
          Grenoble et agglomération.
        </p>
        <p class="text-xs text-steel/60">
          RGE · Professionnel du Gaz · Garantie décennale
        </p>
      </div>

      <div>
        <h4 class="font-heading text-white text-lg font-bold mb-4">Navigation</h4>
        <ul class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-sky transition-colors duration-200">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading text-white text-lg font-bold mb-4">Contact</h4>
        <div class="flex flex-col gap-3 text-sm">
          <p>8 rue des Compagnons<br />38000 Grenoble</p>
          <p><a href="tel:0476000000" class="text-copper hover:text-copper-dark transition-colors duration-200 font-semibold">04 76 00 00 00</a></p>
          <p>contact@duval-plomberie.fr</p>
          <p class="text-xs text-steel/60 mt-2">Lun–Ven : 7h30–18h · Urgences 24h/24</p>
        </div>
      </div>
    </div>

    <div class="border-t border-deep-light pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs">&copy; 2026 Duval Plomberie. Tous droits réservés.</p>
      <p class="text-xs">
        Site réalisé par
        <a href="https://mouilleronweb.netlify.app" target="_blank" rel="noopener noreferrer" class="text-sky hover:text-sky-dark transition-colors duration-200">Mouilleron Web</a>
      </p>
    </div>
  </div>
</footer>
