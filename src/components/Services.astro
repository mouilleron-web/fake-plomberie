---
const services = [
  {
    title: "Plomberie générale",
    description: "Robinetterie, canalisations, sanitaires. Installation et réparation de tous vos équipements de plomberie.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />`,
  },
  {
    title: "Chauffage",
    description: "Installation et entretien de chaudières gaz, pompes à chaleur, planchers chauffants et radiateurs.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />`,
  },
  {
    title: "Salle de bain",
    description: "Rénovation complète clé en main : douche, baignoire, meuble vasque, carrelage, agencement sur mesure.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  },
  {
    title: "Dépannage urgent",
    description: "Fuites, bouchons, pannes de chaudière. Intervention rapide sur Grenoble et agglomération, 7j/7.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1a7.065 7.065 0 010-10l.354-.354a.75.75 0 011.06 0l5.1 5.1m-5.1 5.1l5.1-5.1m-5.1 5.1L5 21m6.42-5.83l5.1 5.1a.75.75 0 001.06 0l.354-.354a7.065 7.065 0 000-10l-5.1-5.1" />`,
  },
];
---

<section class="bg-mist py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-copper font-semibold mb-3 text-sm tracking-[0.2em] uppercase">Ce que nous faisons</p>
      <h2 class="text-3xl md:text-4xl font-extrabold">Nos domaines d'expertise</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <div class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 border border-mist-dark hover:border-sky/30">
          <div class="w-14 h-14 bg-sky/10 rounded-xl flex items-center justify-center mb-5 group-hover:bg-sky/20 transition-colors duration-300">
            <svg class="w-7 h-7 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <Fragment set:html={service.icon} />
            </svg>
          </div>
          <h3 class="font-heading text-lg font-bold mb-2">{service.title}</h3>
          <p class="text-steel text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/services" class="inline-flex items-center gap-2 text-sky font-semibold hover:text-sky-dark transition-colors duration-200">
        Tous nos services
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
