---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: "Plomberie générale",
    description: "De la simple réparation de robinet à la refonte complète de votre réseau de canalisations, nous intervenons sur tous vos équipements sanitaires.",
    items: ["Installation et remplacement de robinetterie", "Réparation de fuites", "Pose de sanitaires (WC, lavabo, bidet)", "Remplacement de canalisations", "Détection de fuites non destructive"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />`,
  },
  {
    title: "Chauffage",
    description: "Installation, entretien et dépannage de tous types de systèmes de chauffage. Nous vous conseillons la solution la plus adaptée à votre logement.",
    items: ["Installation chaudière gaz condensation", "Pompe à chaleur air-eau", "Plancher chauffant hydraulique", "Pose et remplacement de radiateurs", "Contrat d'entretien annuel"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" />`,
  },
  {
    title: "Salle de bain clé en main",
    description: "De la conception à la réalisation, nous prenons en charge l'intégralité de votre projet de salle de bain : plomberie, carrelage, agencement.",
    items: ["Étude et conception du projet", "Dépose de l'existant", "Plomberie et évacuations", "Pose douche italienne ou baignoire", "Meuble vasque et accessoires"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
  },
  {
    title: "Dépannage & urgences",
    description: "Une fuite, un bouchon, une panne de chaudière en plein hiver ? Nous intervenons rapidement, 7 jours sur 7, sur toute l'agglomération grenobloise.",
    items: ["Fuite d'eau urgente", "Débouchage canalisation", "Panne de chaudière", "WC bouché", "Intervention 24h/24, 7j/7"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1a7.065 7.065 0 010-10l.354-.354a.75.75 0 011.06 0l5.1 5.1m-5.1 5.1l5.1-5.1m-5.1 5.1L5 21m6.42-5.83l5.1 5.1a.75.75 0 001.06 0l.354-.354a7.065 7.065 0 000-10l-5.1-5.1" />`,
  },
  {
    title: "Chauffe-eau & ballon",
    description: "Installation et remplacement de chauffe-eau électriques, thermodynamiques ou solaires. Nous vous aidons à choisir la capacité adaptée.",
    items: ["Chauffe-eau électrique (50 à 300L)", "Chauffe-eau thermodynamique", "Chauffe-eau solaire", "Détartrage et maintenance", "Remplacement en urgence"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 10.5h.375c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125H21M3.75 18h15A2.25 2.25 0 0021 15.75v-6a2.25 2.25 0 00-2.25-2.25h-15A2.25 2.25 0 001.5 9.75v6A2.25 2.25 0 003.75 18z" />`,
  },
  {
    title: "Traitement de l'eau",
    description: "Protégez vos installations et améliorez la qualité de votre eau avec nos solutions d'adoucissement et de filtration.",
    items: ["Adoucisseur d'eau", "Filtre anti-calcaire", "Osmoseur sous évier", "Analyse de la dureté de l'eau", "Contrat d'entretien"],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />`,
  },
];
---

<Layout title="Nos Services — Duval Plomberie">
  <Header />
  <main>
    <PageHero title="Nos Services" subtitle="Des solutions pour chaque besoin" />

    {services.map((service, i) => (
      <section class={i % 2 === 0 ? "bg-mist py-16 md:py-20" : "bg-mist-dark py-16 md:py-20"}>
        <div class="max-w-6xl mx-auto px-6">
          <div class="flex flex-col md:flex-row gap-10 items-start">
            <div class="md:w-1/3 shrink-0">
              <div class="sticky top-24">
                <div class="w-16 h-16 bg-sky/10 rounded-2xl flex items-center justify-center mb-4">
                  <svg class="w-8 h-8 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <Fragment set:html={service.icon} />
                  </svg>
                </div>
                <h2 class="font-heading text-2xl md:text-3xl font-bold">{service.title}</h2>
              </div>
            </div>
            <div class="md:w-2/3">
              <p class="text-steel text-lg leading-relaxed mb-6">{service.description}</p>
              <ul class="space-y-3">
                {service.items.map((item) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-copper shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>
    ))}

    <section class="bg-deep py-12">
      <div class="max-w-6xl mx-auto px-6 text-center">
        <p class="text-white text-lg font-heading font-bold mb-4">Un projet en tête ?</p>
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 bg-copper text-white font-bold rounded-xl hover:bg-copper-dark transition-colors duration-200">
          Demander un devis gratuit
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
