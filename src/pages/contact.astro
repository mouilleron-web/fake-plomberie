---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Devis & Contact — Duval Plomberie">
  <Header />
  <main>
    <PageHero title="Devis & Contact" subtitle="Parlons de votre projet" />

    <section class="bg-mist py-16 md:py-20">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold mb-6">Demander un devis</h2>
            <p class="text-steel mb-8">Décrivez votre projet et nous vous recontactons sous 24 heures avec un devis détaillé et gratuit.</p>
            <form class="space-y-5">
              <div>
                <label for="name" class="block text-sm font-semibold mb-2">Nom complet</label>
                <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-mist-dark bg-white focus:outline-none focus:border-sky focus:ring-2 focus:ring-sky/20 transition-colors" placeholder="Votre nom" />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="email" class="block text-sm font-semibold mb-2">Email</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-mist-dark bg-white focus:outline-none focus:border-sky focus:ring-2 focus:ring-sky/20 transition-colors" placeholder="votre@email.fr" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold mb-2">Téléphone</label>
                  <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-mist-dark bg-white focus:outline-none focus:border-sky focus:ring-2 focus:ring-sky/20 transition-colors" placeholder="06 00 00 00 00" />
                </div>
              </div>
              <div>
                <label for="service" class="block text-sm font-semibold mb-2">Type de prestation</label>
                <select id="service" name="service" class="w-full px-4 py-3 rounded-xl border border-mist-dark bg-white focus:outline-none focus:border-sky focus:ring-2 focus:ring-sky/20 transition-colors">
                  <option value="">Sélectionnez...</option>
                  <option value="plomberie">Plomberie générale</option>
                  <option value="chauffage">Chauffage</option>
                  <option value="sdb">Salle de bain</option>
                  <option value="depannage">Dépannage urgent</option>
                  <option value="chauffe-eau">Chauffe-eau</option>
                  <option value="eau">Traitement de l'eau</option>
                  <option value="autre">Autre</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold mb-2">Description du projet</label>
                <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-mist-dark bg-white focus:outline-none focus:border-sky focus:ring-2 focus:ring-sky/20 transition-colors resize-none" placeholder="Décrivez votre besoin..."></textarea>
              </div>
              <button type="submit" class="w-full sm:w-auto px-8 py-4 bg-sky text-white font-bold rounded-xl hover:bg-sky-dark transition-colors duration-200 shadow-lg shadow-sky/20">Envoyer ma demande</button>
            </form>
          </div>

          <div>
            <h2 class="font-heading text-2xl md:text-3xl font-bold mb-6">Nos coordonnées</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sky/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold mb-1">Adresse</p>
                  <p class="text-steel">8 rue des Compagnons<br />38000 Grenoble</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sky/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold mb-1">Téléphone</p>
                  <p class="text-steel"><a href="tel:0476000000" class="text-copper hover:text-copper-dark transition-colors">04 76 00 00 00</a></p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sky/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold mb-1">Email</p>
                  <p class="text-steel">contact@duval-plomberie.fr</p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-sky/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-sky" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold mb-1">Horaires</p>
                  <p class="text-steel text-sm">
                    Lundi – Vendredi : 7h30 — 18h00<br />
                    Samedi : sur rendez-vous<br />
                    <span class="text-copper font-semibold">Urgences : 24h/24, 7j/7</span>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="bg-copper py-4">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-4 text-white font-bold text-center">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        <span>Urgence plomberie ? Appelez le <a href="tel:0476000000" class="underline">04 76 00 00 00</a> — Intervention rapide 24h/24</span>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
